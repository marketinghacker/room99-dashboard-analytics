# ---------------------------------------------------------------------------
# Room99 Dashboard — environment variables
# Copy to .env.local for local development.
# Fill the same keys in Railway → Variables for production.
# ---------------------------------------------------------------------------

# Postgres connection (Railway provides $DATABASE_URL automatically when the
# service is linked to the `room99-postgres` plugin. Locally use the public
# proxy URL from Railway dashboard.
DATABASE_URL=postgresql://postgres:<PASSWORD>@<HOST>:<PORT>/railway

# Cron-protected routes: `/api/cron/sync?key=$CRON_SECRET`
CRON_SECRET=change-me-to-a-random-string

# ---- MCP server URLs (Room99 agency-managed Railway services) -------------
MCP_META_ADS_URL=https://mcp-meta.up.railway.app/mcp
MCP_GOOGLE_ADS_URL=https://google-ads-mcp-server-production-7a5f.up.railway.app/mcp
MCP_CRITEO_URL=https://mcp-criteo.up.railway.app/mcp
MCP_GA4_URL=https://mcp-analytics.up.railway.app/mcp
MCP_BASELINKER_URL=https://mcp-sellrocket.up.railway.app/mcp
MCP_PINTEREST_URL=https://mh-connector.up.railway.app/mcp

# user_id under which each platform's OAuth token is stored on the MCP server.
# MCP servers keep no 'active user' state, so each tool call must pass user_id
# explicitly when more than one user is authorized on that server.
MCP_PINTEREST_USER_ID=marcin@marketing-hackers.com
MCP_GA4_USER_ID=marcin@marketing-hackers.com

# ---- Platform account IDs (Room99) ----------------------------------------
META_ACCOUNT_ID=act_295812916
GOOGLE_ADS_CUSTOMER_ID=1331139339
CRITEO_ADVERTISER_ID=55483
GA4_PROPERTY_ID=315856757
PINTEREST_AD_ACCOUNT_ID=549764456968

# ---- Optional ------------------------------------------------------------
# Sentry (leave blank to disable)
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# Admin panel password (for /admin/settings)
ADMIN_PASSWORD=room99admin
